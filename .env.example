# AI-powered search (chatbot uses this; falls back gracefully if missing)
GROQ_API_KEY=hghjhjh

# Required in production — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=replace-with-a-long-random-secret
# Set to your production URL, e.g. https://simba-supermarket.vercel.app
NEXTAUTH_URL=https://your-domain.com

# Optional — enables Google OAuth login
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
